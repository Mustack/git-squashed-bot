# Discord bot token (create app at https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Channel where the bot posts the weekly poll (required for Sunday auto-post).
# Right-click the channel in Discord → Copy channel ID (enable Developer Mode in settings).
DISCORD_POLL_CHANNEL_ID=

# Optional: time to post the weekly poll on Sundays (US Eastern Time, America/New_York). Examples: 12:35pm, 9am, 18:00 (default: 12:35pm)
# POLL_TIME=12:35pm

# Optional: command prefix (default: !)
# COMMAND_PREFIX=!

# Optional: time to run the booking script (US Eastern Time, America/New_York). Examples: 12:45pm, 6pm, 18:00 (default: 12:45pm)
# BOOKING_TIME=12:45pm

# Optional: for your booking script (scripts/book-courts.mjs)
# BOOKING_URL=https://reservation.frontdesksuite.ca/rcfs/bobmacquarrie
# BOOKING_USER=
# BOOKING_PASSWORD=
# HEADLESS=false

# Day and time for testing (defaults: Tuesday, 8:00 p.m.)
# BOOKING_DAY=Tuesday
# BOOKING_TIME=8:00 p.m.

# Contact details for the reservation form (required when DRY_RUN is false)
BOOKING_PHONE=6135551234
BOOKING_EMAIL=you@example.com
BOOKING_NAME=Your Name

# When true, navigate through the flow but skip entering contact info and submitting.
# Useful for testing selectors and availability logic without actually booking.
DRY_RUN=true

# Optional: extra delay (ms) after each click in DRY_RUN mode (for easier visual debugging).
# Default is 2000 if unset.
DRY_RUN_CLICK_DELAY=300

# Optional: set a channel ID to record Playwright booking runs and upload the video there. Unset = no recording.
# DISCORD_VIDEO_CHANNEL_ID=
