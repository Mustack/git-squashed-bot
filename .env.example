# Discord bot token (create app at https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Channel where the bot posts the weekly poll (required for Sunday auto-post).
# Right-click the channel in Discord → Copy channel ID (enable Developer Mode in settings).
DISCORD_POLL_CHANNEL_ID=

# Optional: time to post the weekly poll on Sundays. Examples: 12:35pm, 9am, 18:00 (default: 12:35pm)
# POLL_TIME=12:35pm

# Optional: command prefix (default: !)
# COMMAND_PREFIX=!

# Optional: time to run the booking script. Examples: 12:45pm, 6pm, 18:00 (default: 12:45pm)
# BOOKING_TIME=12:45pm

# Optional: for your booking script (scripts/book-courts.mjs)
# BOOKING_URL=https://reservation.frontdesksuite.ca/rcfs/bobmacquarrie
# BOOKING_USER=
# BOOKING_PASSWORD=
# HEADLESS=false

# Day and time for testing (defaults: Tuesday, 8:00 p.m.)
# BOOKING_DAY=Tuesday
# BOOKING_TIME=8:00 p.m.

# Contact details for the reservation form (required for booking)
BOOKING_PHONE=6135551234
BOOKING_EMAIL=you@example.com
BOOKING_NAME=Your Name
